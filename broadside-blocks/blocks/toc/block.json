{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "broadside/toc",
	"title": "Table of Contents",
	"category": "broadside",
	"icon": "list-view",
	"description": "Builds itself from the headings in this post. Rename a heading and the contents follow — there is nothing to keep in sync by hand.",
	"keywords": [ "contents", "toc", "outline", "jump links", "in this article" ],
	"textdomain": "broadside-blocks",
	"supports": {
		"html": false,
		"anchor": true,
		"multiple": false,
		"spacing": {
			"margin": [ "top", "bottom" ]
		}
	},
	"attributes": {
		"label": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:../../assets/js/blocks.js",
	"style": "broadside"
}
