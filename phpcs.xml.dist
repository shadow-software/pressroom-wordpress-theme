<?xml version="1.0"?>
<ruleset name="Digest">
	<description>
		Coding standards for the Digest theme.

		WordPress-Extra + WordPress-Docs, which is what the WordPress.org Theme
		Directory actually runs against a submission. Passing this locally is the
		cheapest way to not be rejected.

		NOTE: this ruleset used to also `<rule ref="WPThemeReview"/>`, and CI used
		to install wptrt/wpthemereview:^0.2 alongside wp-coding-standards/wpcs:^3.
		Those two are MUTUALLY EXCLUSIVE — wpthemereview 0.2 requires WPCS ^2 —
		so `composer require` failed outright and the "WordPress Coding Standards
		+ Theme Review" CI job had never once run a single sniff. WPThemeReview is
		unmaintained and its sniffs were folded into WPCS 3's WordPress-Extra, so
		the fix is to drop it rather than pin WPCS back to 2.x.
	</description>

	<file>shadow-software-digest-theme-for-wordpress</file>

	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/assets/fonts/*</exclude-pattern>

	<arg value="ps"/>
	<arg name="colors"/>
	<arg name="parallel" value="8"/>
	<arg name="extensions" value="php"/>

	<rule ref="WordPress-Extra"/>
	<rule ref="WordPress-Docs"/>

	<!--
		A doc comment whose first word is a FUNCTION NAME — "get_avatar() is a
		Gravatar call…", "sanitize_text_field() strips newlines…" — trips this
		sniff, which wants a capital letter. Capitalising them would make the
		documentation wrong: there is no Get_avatar(). The sniff cannot tell prose
		from an identifier, so it is excluded rather than obeyed.
	-->
	<rule ref="Generic.Commenting.DocComment.LongNotCapital">
		<severity>0</severity>
	</rule>

	<!--
		Text domain enforcement: every translatable string in the theme must use
		the theme's own text domain, which must match the directory name. The
		Theme Directory rejects a mismatch outright.
	-->
	<config name="text_domain" value="shadow-software-digest-theme-for-wordpress"/>
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="shadow-software-digest-theme-for-wordpress"/>
			</property>
		</properties>
	</rule>

	<!--
		Prefix enforcement. Every function, class, constant and global the theme
		defines must carry one of these prefixes, so a theme can never collide
		with a plugin or with core.
	-->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="shadow_digest"/>
				<element value="SHADOW_DIGEST"/>
			</property>
		</properties>
	</rule>

	<!-- The minimum versions declared in style.css. -->
	<config name="minimum_wp_version" value="6.6"/>
	<config name="testVersion" value="8.0-"/>
	<rule ref="PHPCompatibilityWP"/>

	<!--
		blocks.asset.php is a dependency manifest that returns an array. It is not
		a class file and has no side effects; the filename sniff does not apply.
	-->
	<rule ref="WordPress.Files.FileName">
		<exclude-pattern>*/assets/js/blocks.asset.php</exclude-pattern>
	</rule>
</ruleset>
