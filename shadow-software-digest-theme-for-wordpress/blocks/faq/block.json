{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "shadow-digest/faq",
	"title": "FAQ",
	"category": "shadow-software-digest-theme-for-wordpress",
	"icon": "editor-help",
	"description": "Questions and answers, which also emit FAQPage structured data so search and answer engines can quote them directly.",
	"keywords": [ "faq", "questions", "answers", "schema", "aeo" ],
	"textdomain": "shadow-software-digest-theme-for-wordpress",
	"supports": {
		"html": false,
		"anchor": true,
		"spacing": {
			"margin": [ "top", "bottom" ]
		}
	},
	"attributes": {
		"title": {
			"type": "string",
			"default": ""
		},
		"items": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object"
			}
		}
	},
	"editorScript": "file:../../assets/js/blocks.js",
	"style": "shadow-software-digest-theme-for-wordpress"
}
