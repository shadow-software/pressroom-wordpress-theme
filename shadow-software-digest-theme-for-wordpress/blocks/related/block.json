{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "shadow-digest/related",
	"title": "Continue Reading",
	"category": "shadow-software-digest-theme-for-wordpress",
	"icon": "list-view",
	"description": "Three more stories from the same section as this one, never including the story the reader is already on.",
	"keywords": [ "related", "continue", "more", "recirculation" ],
	"textdomain": "shadow-software-digest-theme-for-wordpress",
	"supports": {
		"html": false,
		"reusable": false,
		"multiple": false,
		"spacing": {
			"margin": [ "top", "bottom" ]
		}
	},
	"attributes": {
		"count": {
			"type": "number",
			"default": 3
		},
		"heading": {
			"type": "string",
			"default": ""
		}
	},
	"style": "shadow-software-digest-theme-for-wordpress"
}
