{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "shadow-digest/short-answer",
	"title": "Short Answer",
	"category": "shadow-software-digest-theme-for-wordpress",
	"icon": "editor-quote",
	"description": "A direct, quotable answer at the top of the article — the two sentences a reader (or a search engine) should get without reading two thousand words first.",
	"keywords": [ "answer", "summary", "snippet", "aeo", "tldr" ],
	"textdomain": "shadow-software-digest-theme-for-wordpress",
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide" ],
		"spacing": {
			"margin": [ "top", "bottom" ]
		}
	},
	"attributes": {
		"label": {
			"type": "string",
			"default": ""
		},
		"answer": {
			"type": "string",
			"default": "",
			"source": "html",
			"selector": ".wp-block-digest-short-answer__body"
		}
	},
	"editorScript": "file:../../assets/js/blocks.js",
	"style": "shadow-software-digest-theme-for-wordpress"
}
